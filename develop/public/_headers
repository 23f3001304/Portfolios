# Vite fingerprints these filenames, so they can be cached forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Long-cache the static media too.
/world/*
  Cache-Control: public, max-age=2592000
/projects/*
  Cache-Control: public, max-age=2592000
/oneko/*
  Cache-Control: public, max-age=2592000
/audio/*
  Cache-Control: public, max-age=2592000
